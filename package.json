{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Implementação do https://www.tabnews.com.br para o https://curso.dev",
  "repository": "https://github.com/diasjoaovitor/clone-tabnews.git",
  "author": "João Vitor <jvitordiass@outlook.com.br>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "./init.sh",
    "build": "next build",
    "start": "next start",
    "test": "./init.sh test",
    "test:watch": "jest --runInBand --watchAll --verbose",
    "services:up": "docker compose -f src/infra/compose.yml up -d",
    "services:stop": "docker compose -f src/infra/compose.yml stop",
    "services:down": "docker compose -f src/infra/compose.yml down",
    "services:wait:database": "node src/infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m src/infra/migrations create",
    "migrations:up": "node-pg-migrate -m src/infra/migrations --envPath .env.development up",
    "migrations:up:dry": "node-pg-migrate -m src/infra/migrations --envPath .env --dry-run up",
    "migrations:up:deploy": "node-pg-migrate -m src/infra/migrations --envPath .env up",
    "eslint:check": "eslint",
    "eslint:fix": "eslint --fix",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.2",
    "dedent": "^1.7.2",
    "next": "15.5.9",
    "node-pg-migrate": "7.8.0",
    "nodemailer": "7.0.9",
    "pg": "8.16.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "setimmediate": "^1.0.5",
    "uuid": "11.1.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "20.1.0",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.37.0",
    "@faker-js/faker": "9.7.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/async-retry": "1.4.9",
    "@types/jest": "30.0.0",
    "@types/node": "24.7.2",
    "@types/nodemailer": "7.0.2",
    "@types/pg": "8.15.5",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.1",
    "@types/set-cookie-parser": "2.4.10",
    "baseline-browser-mapping": "^2.10.0",
    "commitlint-config-emoji-convention": "1.0.3",
    "concurrently": "9.2.1",
    "cross-fetch": "4.1.0",
    "dotenv": "17.2.3",
    "dotenv-expand": "12.0.3",
    "eslint": "9",
    "eslint-config-next": "15.5.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.0.1",
    "eslint-plugin-react-hooks": "7.0.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "lint-staged": "16.2.4",
    "prettier": "3.6.2",
    "set-cookie-parser": "2.7.1",
    "typescript": "5.9.3"
  }
}
